# Copy to .env and fill in. .env is git-ignored.

# --- Option A (recommended): a single managed-Postgres connection string ---
# Supabase: Project Settings -> Database -> Connection string (URI).
# Use the "Session pooler" or "Direct connection" string. Example shape:
# DATABASE_URL="postgresql://postgres.abcxyz:YOUR-PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"
DATABASE_URL=

# --- Option B: discrete fields (used only if DATABASE_URL is empty) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iivas
DB_USER=iivas
DB_PASSWORD=change_me

# --- SEC EDGAR: REQUIRED. Must contain a real contact email. ---
SEC_USER_AGENT="IIVAS Research your_name your_email@example.com"
